# Vendored static libav (FFmpeg) binaries + headers — bundle-local, not source.
# See ThirdParty/ffmpeg/README.md for provenance/rebuild. Keep the README tracked.
ThirdParty/ffmpeg/lib/
ThirdParty/ffmpeg/include/

# Vendored static libdatachannel (WHEP WebRTC transport) + its deps — build outputs, not source.
# See ThirdParty/libdatachannel/README.md for provenance; scripts/build_mbedtls.sh then
# scripts/build_libdatachannel.sh to rebuild.
# Keep the README and the build script tracked.
ThirdParty/libdatachannel/lib/
ThirdParty/libdatachannel/include/

docs/BlackmagicDeckLinkSDK16.0/
docs/Blackmagic Advanced Video Capture and Playback/
.DS_Store

# NDI SDK — licensed, NOT redistributable, and deliberately NOT vendored. The headers are
# referenced at their system path (/Library/NDI SDK for Apple/include, see project.yml) and the
# runtime dylib is dlopen'd, never linked or bundled. These patterns exist so a stray copy of the
# SDK can't be committed by accident; there should be nothing NDI-derived in this repo to ignore.
NDI SDK*/
ThirdParty/NDI/
**/libndi*.dylib
**/Processing.NDI.*.h

# WHEP endpoint config — the URL embeds a stream key, so it is a SECRET. The file the app
# actually reads is ~/.manifold-whep-config, deliberately OUTSIDE the working tree: a file
# that isn't in the repo cannot be committed by accident, force-added, or swept into an
# archive of the source directory. These patterns exist only so a stray copy dropped in the
# repo can't be committed either. There should be nothing here to ignore.
.whep-config
.manifold-whep-config
*.whep-url

docs/Blackmagic Advanced Video Capture and Playback/
